# OpenAI API key (required for agent + validation classifiers)
OPENAI_API_KEY=your_openai_key_here

# SerpAPI key (required for flights, hotels, cultural guide)
SERPAPI_API_KEY=your_serpapi_key_here

# ── Observability ──────────────────────────────────────────────────────────
# Options: phoenix | arize | both | none
OTEL_DESTINATION=phoenix
# Project name in Phoenix/Arize dashboards
OTEL_PROJECT_NAME=travelshaper

# ── Local Phoenix ──────────────────────────────────────────────────────────
PHOENIX_ENDPOINT=http://localhost:6006/v1/traces
# PHOENIX_API_KEY=                        # only needed for Phoenix Cloud

# ── Arize Cloud ────────────────────────────────────────────────────────────
# ARIZE_API_KEY=
# ARIZE_SPACE_ID=
