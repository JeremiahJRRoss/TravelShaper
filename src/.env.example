# OpenAI API key (required for agent + validation classifiers)
OPENAI_API_KEY=your_openai_key_here

# SerpAPI key (required for flights, hotels, cultural guide)
SERPAPI_API_KEY=your_serpapi_key_here

# Phoenix collector endpoint
# For local/venv development: http://localhost:6006/v1/traces
# Docker Compose overrides this to http://phoenix:6006/v1/traces automatically
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
